{
  "name": "home-canvas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.mjs",
  "description": "Home Canvas desktop app",
  "author": "Home Canvas",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "start": "vite preview --open",
    "test:e2e": "playwright test",
    "test:e2e-ui": "playwright test --ui",
    "dev:app": "concurrently -n VITE,ELECTRON -c blue,green \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build:renderer": "vite build",
  "build:app": "npm run build:renderer && electron-builder -w",
  "cap:init": "cap init com.homecanvas.app \"Home Canvas\" --web-dir=dist -y",
  "cap:sync": "npm run build && cap sync",
  "cap:android": "npm run build && cap add android && cap sync android",
  "android:open": "cap open android"
  },
  "dependencies": {
    "@google/genai": "^1.10.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.3",
  "@types/node": "^22.14.0",
  "typescript": "~5.6.3",
    "vite": "^6.0.3",
    "concurrently": "^8.2.2",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
  "wait-on": "^7.2.0",
  "@capacitor/android": "^6.1.4",
  "@capacitor/cli": "^6.1.4",
  "@capacitor/core": "^6.1.4"
  },
  "build": {
    "appId": "com.homecanvas.app",
    "productName": "Home Canvas",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  }
}