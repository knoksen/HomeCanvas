{
  "name": "home-canvas",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "main": "electron/main.mjs",
  "description": "Home Canvas desktop app",
  "author": "Home Canvas",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "start": "vite preview --open",
    "test:e2e": "playwright test",
    "test:e2e-ui": "playwright test --ui",
    "dev:app": "concurrently -n VITE,ELECTRON -c blue,green \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build:renderer": "vite build",
    "build:app": "npm run build:renderer && electron-builder -w",
    "cap:init": "cap init com.homecanvas.app \"Home Canvas\" --web-dir=dist -y",
    "cap:sync": "npm run build && cap sync",
    "cap:android": "npm run build && cap add android && cap sync android",
    "android:open": "cap open android",
    "lint": "eslint . --ext .ts,.tsx",
  "lint:md": "markdownlint '**/*.md' --ignore node_modules",
  "dev:server": "nodemon --watch server --ext ts --exec ts-node server/proxy.ts",
  "build:server": "tsc --project tsconfig.json --outDir dist-server --module commonjs --esModuleInterop",
  "test:unit": "vitest run",
  "test:unit:watch": "vitest",
    "dev:full": "concurrently -n VITE,SERVER -c blue,magenta \"vite\" \"npm run dev:server\"",
  "start:electron": "cross-env NODE_ENV=production electron .",
  "start:proxy": "node dist-server/server/proxy.js"
  },
  "dependencies": {
    "@google/genai": "^1.10.0",
    "cors": "^2.8.5",
  "express": "^4.19.2",
  "express-rate-limit": "^7.4.0",
  "helmet": "^7.1.0",
    "node-fetch": "^3.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@capacitor/android": "^6.1.4",
    "@capacitor/cli": "^6.1.4",
    "@capacitor/core": "^7.4.4",
    "@playwright/test": "^1.45.3",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@types/node": "^24.9.1",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.3.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.11.1",
    "eslint-plugin-react-hooks": "^5.0.0",
  "eslint-plugin-react-refresh": "^0.4.7",
  "@types/helmet": "^4.0.0",
  "@types/express-rate-limit": "^5.1.3",
  "@vercel/node": "^3.0.20",
  "@netlify/functions": "^2.8.1",
  "@testing-library/dom": "^10.4.0",
  "@testing-library/react": "^16.0.0",
  "@types/jsdom": "^21.1.7",
  "supertest": "^7.1.1",
  "@types/supertest": "^2.0.16",
    "markdownlint-cli": "^0.41.0",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3",
  "vite": "^7.1.12",
  "wait-on": "^7.2.0",
  "dotenv": "^16.4.5"
  ,"vitest": "^2.1.1",
  "@vitest/coverage-v8": "^2.1.1",
  "jsdom": "^25.0.0"
  },
  "overrides": {},
  "build": {
    "appId": "com.homecanvas.app",
    "productName": "Home Canvas",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  }
}
